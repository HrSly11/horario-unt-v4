generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Facultad {
  id            String                 @id @default(cuid())
  nombre        String                 @unique
  siglas        String                 @unique
  decanoId      String?                @unique @map("decano_id")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  decano        User?                  @relation("DecanoFacultad", fields: [decanoId], references: [id])
  departamentos Departamento[]
  escuelas      Escuela[]
  cargos        CargoDocente[]
  publicaciones PublicacionAcademica[]

  @@map("facultades")
}

model Departamento {
  id               String                @id @default(cuid())
  nombre           String
  facultadId       String                @map("facultad_id")
  directorId       String?               @unique @map("director_id")
  secretariaId     String?               @unique @map("secretaria_id")
  designadoPorId   String?               @map("designado_por_id")
  fechaDesignacion DateTime?             @map("fecha_designacion")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  designadoPor     User?                 @relation("DesignadorDepartamento", fields: [designadoPorId], references: [id])
  director         User?                 @relation("DirectorDepartamento", fields: [directorId], references: [id])
  facultad         Facultad              @relation(fields: [facultadId], references: [id], onDelete: Cascade)
  secretaria       User?                 @relation("SecretariaDepartamento", fields: [secretariaId], references: [id])
  cursos           Curso[]
  docentes         Docente[]
  demandas         DemandaLinea[]
  distribuciones   DistribucionLectiva[]
  cargos           CargoDocente[]

  @@unique([nombre, facultadId])
  @@map("departamentos")
}

model Escuela {
  id               String                  @id @default(cuid())
  nombre           String
  facultadId       String                  @map("facultad_id")
  directorId       String?                 @unique @map("director_id")
  secretariaId     String?                 @unique @map("secretaria_id")
  designadoPorId   String?                 @map("designado_por_id")
  fechaDesignacion DateTime?               @map("fecha_designacion")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  curriculas       Curricula[]
  designadoPor     User?                   @relation("DesignadorEscuela", fields: [designadoPorId], references: [id])
  director         User?                   @relation("DirectorEscuela", fields: [directorId], references: [id])
  secretaria       User?                   @relation("SecretariaEscuela", fields: [secretariaId], references: [id])
  facultad         Facultad                @relation(fields: [facultadId], references: [id], onDelete: Cascade)
  demandas         DemandaAcademica[]
  procesosHorario  ProcesoHorarioEscuela[]
  cargos           CargoDocente[]

  @@unique([nombre, facultadId])
  @@map("escuelas")
}

model Curricula {
  id                    String                  @id @default(cuid())
  codigo                String
  escuelaId             String                  @map("escuela_id")
  vigente               Boolean                 @default(true)
  estado                EstadoCurricula         @default(ACTIVA)
  estudiantesPendientes Int                     @default(0) @map("estudiantes_pendientes")
  cerradaEn             DateTime?               @map("cerrada_en")
  cerradaPorId          String?                 @map("cerrada_por_id")
  anio                  Int
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  cerradaPor            User?                   @relation("CurriculaCerradaPor", fields: [cerradaPorId], references: [id])
  escuela               Escuela                 @relation(fields: [escuelaId], references: [id], onDelete: Restrict)
  cursos                CursoCurricula[]
  demandas              DemandaLineaCurricula[]

  @@unique([codigo, escuelaId])
  @@map("curriculas")
}

model CursoCurricula {
  id            String    @id @default(cuid())
  cursoId       String    @map("curso_id")
  curriculaId   String    @map("curricula_id")
  ciclo         Int
  esElectivo    Boolean   @default(false) @map("es_electivo")
  asociadaEn    DateTime  @default(now()) @map("asociada_en")
  desasociadaEn DateTime? @map("desasociada_en")
  curricula     Curricula @relation(fields: [curriculaId], references: [id], onDelete: Restrict)
  curso         Curso     @relation(fields: [cursoId], references: [id], onDelete: Restrict)

  @@unique([cursoId, curriculaId])
  @@map("cursos_curriculas")
}

model User {
  id                        String                    @id @default(cuid())
  email                     String                    @unique
  password                  String
  nombre                    String
  role                      UserRole                  @default(DOCENTE)
  activo                    Boolean                   @default(true)
  docenteId                 String?                   @unique @map("docente_id")
  createdAt                 DateTime                  @default(now()) @map("created_at")
  updatedAt                 DateTime                  @updatedAt @map("updated_at")
  declaracionesAprobDepto   DeclaracionCarga[]        @relation("AprobadorDepto")
  declaracionesAprobEscuela DeclaracionCarga[]        @relation("AprobadorEscuela")
  declaracionesVBDecano     DeclaracionCarga[]        @relation("VBDecano")
  designacionesDepartamento Departamento[]            @relation("DesignadorDepartamento")
  departamentoDirigido      Departamento?             @relation("DirectorDepartamento")
  departamentoSecretaria    Departamento?             @relation("SecretariaDepartamento")
  facultadDecanada          Facultad?                 @relation("DecanoFacultad")
  firmasDigitales           DocumentoFirmaDigital[]   @relation("FirmanteDocumento")
  designacionesEscuela      Escuela[]                 @relation("DesignadorEscuela")
  escuelaDirigida           Escuela?                  @relation("DirectorEscuela")
  escuelaSecretaria         Escuela?                  @relation("SecretariaEscuela")
  curriculasCerradas        Curricula[]               @relation("CurriculaCerradaPor")
  demandasEnviadas          DemandaAcademica[]        @relation("DemandaEnviadaPor")
  demandasRevisadas         DemandaAcademica[]        @relation("DemandaRevisadaPor")
  distribucionesEnviadas    DistribucionLectiva[]     @relation("DistribucionEnviadaPor")
  distribucionesRevisadas   DistribucionLectiva[]     @relation("DistribucionRevisadaPor")
  procesosRevisados         ProcesoHorarioEscuela[]   @relation("ProcesoHorarioRevisadoPor")
  procesosPublicados        ProcesoHorarioEscuela[]   @relation("ProcesoHorarioPublicadoPor")
  publicaciones             PublicacionAcademica[]    @relation("PublicacionRealizadaPor")
  reconciliacionesResueltas MigracionReconciliacion[] @relation("ReconciliacionResueltaPor")
  notificaciones            Notification[]            @relation("NotificationRecipient")
  logs                      Log[]
  periodosAprobados         PeriodoAcademico[]        @relation("AprobadorPeriodo")
  docente                   Docente?                  @relation(fields: [docenteId], references: [id])

  @@map("users")
}

model Log {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  accion        String
  detalles      String?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")
  entidad       String?
  entidadId     String?  @map("entidad_id")
  antes         Json?
  despues       Json?
  motivo        String?
  correlationId String?  @map("correlation_id")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([entidad, entidadId])
  @@index([correlationId])
  @@map("logs")
}

model Docente {
  id                          String                   @id @default(cuid())
  codigo                      String?                  @unique
  nombre                      String
  email                       String                   @unique
  categoria                   CategoriaDocente
  tipo                        TipoDocente
  modalidad                   ModalidadDocente         @default(TIEMPO_COMPLETO)
  antiguedad                  DateTime
  activo                      Boolean                  @default(true)
  gradoAcademico              String?                  @map("grado_academico")
  especialidad                String?
  experienciaAnios            Int                      @default(0) @map("experiencia_anios")
  perfilAcademico             String?                  @map("perfil_academico")
  dni                         String?                  @unique
  codigoIBM                   String?                  @unique @map("codigo_ibm")
  departamentoId              String?                  @map("departamento_id")
  horasContrato               Int                      @default(40) @map("horas_contrato")
  dictaOtraUniversidad        Boolean                  @default(false) @map("dicta_otra_universidad")
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")
  asignaciones                Asignacion[]
  asignacionesCargaCompartida AsignacionCargaLectiva[] @relation("DocenteCompartido")
  asignacionesCarga           AsignacionCargaLectiva[]
  cargasNoLectivas            CargaNoLectiva[]
  cargos                      CargoDocente[]
  declaraciones               DeclaracionCarga[]
  disponibilidades            DisponibilidadDocente[]
  docenteGrupos               DocenteGrupo[]
  departamento                Departamento?            @relation(fields: [departamentoId], references: [id])
  notificaciones              Notification[]
  postulaciones               PostulacionCurso[]
  preasignaciones             Preasignacion[]
  restricciones               RestriccionDocente[]
  user                        User?

  @@index([tipo, categoria, antiguedad])
  @@map("docentes")
}

model Notification {
  id              String   @id @default(cuid())
  docenteId       String?  @map("docente_id")
  recipientUserId String?  @map("recipient_user_id")
  titulo          String
  mensaje         String
  leida           Boolean  @default(false)
  tipo            String   @default("INFO")
  link            String?
  createdAt       DateTime @default(now()) @map("created_at")
  docente         Docente? @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  recipient       User?    @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Curso {
  id                        String             @id @default(cuid())
  codigo                    String             @unique
  nombre                    String
  creditos                  Int
  horasTeoria               Int                @map("horas_teoria")
  horasPractica             Int                @default(0) @map("horas_practica")
  horasLaboratorio          Int                @default(0) @map("horas_laboratorio")
  numGruposLaboratorio      Int                @default(1) @map("num_grupos_laboratorio")
  ciclo                     Int
  requiereLaboratorio       Boolean            @default(false) @map("requiere_laboratorio")
  perfilRequerido           String?            @map("perfil_requerido")
  gradoRequerido            String?            @map("grado_requerido")
  experienciaMinima         Int                @default(0) @map("experiencia_minima")
  especialidadRequerida     String?            @map("especialidad_requerida")
  aperturado                Boolean            @default(false)
  motivoAperturaExcepcional String?            @map("motivo_apertura_excepcional")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")
  condicion                 String?            @default("O")
  departamento              String?
  departamentoId            String?            @map("departamento_id")
  requisitos                String?
  cursoCurriculas           CursoCurricula[]
  departamentoOwner         Departamento?      @relation(fields: [departamentoId], references: [id])
  demandas                  DemandaLinea[]
  grupos                    Grupo[]
  postulaciones             PostulacionCurso[]

  @@map("cursos")
}

model DisponibilidadDocente {
  id              String           @id @default(cuid())
  docenteId       String           @map("docente_id")
  grupoId         String?          @map("grupo_id")
  tipo            TipoAsignacion?
  franjaHorariaId String           @map("franja_horaria_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  periodoId       String           @map("periodo_id")
  docente         Docente          @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  grupo           Grupo?           @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  franjaHoraria   FranjaHoraria    @relation(fields: [franjaHorariaId], references: [id], onDelete: Cascade)
  periodo         PeriodoAcademico @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  @@unique([docenteId, periodoId, franjaHorariaId, grupoId, tipo])
  @@map("disponibilidades_docentes")
}

model PostulacionCurso {
  id             String   @id @default(cuid())
  docenteId      String   @map("docente_id")
  cursoId        String   @map("curso_id")
  prioridad      Int      @default(1)
  compatibilidad Float    @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  curso          Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  docente        Docente  @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  @@unique([docenteId, cursoId])
  @@map("postulaciones_cursos")
}

model Grupo {
  id                 String                   @id @default(cuid())
  nombre             String
  seccion            String?
  cursoId            String                   @map("curso_id")
  periodoAcademicoId String                   @map("periodo_academico_id")
  numAlumnos         Int                      @default(0) @map("num_alumnos")
  demandaLineaId     String?                  @map("demanda_linea_id")
  procesoHorarioId   String?                  @map("proceso_horario_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  asignaciones       Asignacion[]
  asignacionesCarga  AsignacionCargaLectiva[]
  docenteGrupos      DocenteGrupo[]
  disponibilidades   DisponibilidadDocente[]
  curso              Curso                    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  periodoAcademico   PeriodoAcademico         @relation(fields: [periodoAcademicoId], references: [id], onDelete: Cascade)
  preasignaciones    Preasignacion[]
  demandaLinea       DemandaLinea?            @relation(fields: [demandaLineaId], references: [id])
  procesoHorario     ProcesoHorarioEscuela?   @relation(fields: [procesoHorarioId], references: [id])

  @@unique([cursoId, nombre, periodoAcademicoId])
  @@map("grupos")
}

model Aula {
  id             String              @id @default(cuid())
  codigo         String              @unique
  nombre         String
  capacidad      Int
  tipo           TipoAula
  edificio       String
  piso           Int
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  asignaciones   Asignacion[]
  mantenimientos MantenimientoAula[]

  @@map("aulas")
}

model PeriodoAcademico {
  id                  String                   @id @default(cuid())
  nombre              String                   @unique
  fechaInicio         DateTime                 @map("fecha_inicio")
  fechaFin            DateTime                 @map("fecha_fin")
  activo              Boolean                  @default(false)
  estado              EstadoPeriodo            @default(PLANIFICACION)
  aprobadoPorId       String?                  @map("aprobado_por_id")
  fechaAprobacion     DateTime?                @map("fecha_aprobacion")
  comentariosDirector String?                  @map("comentarios_director")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  asignaciones        Asignacion[]
  asignacionesCarga   AsignacionCargaLectiva[]
  cargasNoLectivas    CargaNoLectiva[]
  declaraciones       DeclaracionCarga[]
  disponibilidades    DisponibilidadDocente[]
  grupos              Grupo[]
  aprobadoPor         User?                    @relation("AprobadorPeriodo", fields: [aprobadoPorId], references: [id])
  preasignaciones     Preasignacion[]
  demandas            DemandaAcademica[]
  distribuciones      DistribucionLectiva[]
  procesosHorario     ProcesoHorarioEscuela[]
  cargos              CargoDocente[]
  publicaciones       PublicacionAcademica[]

  @@map("periodos_academicos")
}

model FranjaHoraria {
  id               String                  @id @default(cuid())
  dia              DiaSemana
  horaInicio       String                  @map("hora_inicio")
  horaFin          String                  @map("hora_fin")
  numeroBloque     Int                     @map("numero_bloque")
  createdAt        DateTime                @default(now()) @map("created_at")
  asignaciones     Asignacion[]
  disponibilidades DisponibilidadDocente[]
  mantenimientos   MantenimientoAula[]
  preasignaciones  Preasignacion[]
  restricciones    RestriccionDocente[]

  @@unique([dia, horaInicio, horaFin])
  @@map("franjas_horarias")
}

model Asignacion {
  id               String                 @id @default(cuid())
  grupoId          String                 @map("grupo_id")
  docenteId        String                 @map("docente_id")
  aulaId           String                 @map("aula_id")
  franjaHorariaId  String                 @map("franja_horaria_id")
  periodoId        String                 @map("periodo_id")
  tipo             TipoAsignacion
  confirmado       Boolean                @default(false)
  procesoHorarioId String?                @map("proceso_horario_id")
  createdAt        DateTime               @default(now()) @map("created_at")
  aula             Aula                   @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  docente          Docente                @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  franjaHoraria    FranjaHoraria          @relation(fields: [franjaHorariaId], references: [id], onDelete: Cascade)
  grupo            Grupo                  @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  periodo          PeriodoAcademico       @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  procesoHorario   ProcesoHorarioEscuela? @relation(fields: [procesoHorarioId], references: [id])

  @@unique([aulaId, franjaHorariaId, periodoId])
  @@unique([docenteId, franjaHorariaId, periodoId])
  @@unique([grupoId, franjaHorariaId, periodoId])
  @@map("asignaciones")
}

model RestriccionDocente {
  id              String          @id @default(cuid())
  docenteId       String          @map("docente_id")
  franjaHorariaId String          @map("franja_horaria_id")
  tipo            TipoRestriccion
  createdAt       DateTime        @default(now()) @map("created_at")
  docente         Docente         @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  franjaHoraria   FranjaHoraria   @relation(fields: [franjaHorariaId], references: [id], onDelete: Cascade)

  @@unique([docenteId, franjaHorariaId])
  @@map("restricciones_docentes")
}

/// Asignación dirección → docente-grupo (qué cursos dicta cada docente)
model DocenteGrupo {
  id        String   @id @default(cuid())
  docenteId String   @map("docente_id")
  grupoId   String   @map("grupo_id")
  createdAt DateTime @default(now()) @map("created_at")
  docente   Docente  @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  grupo     Grupo    @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@unique([docenteId, grupoId])
  @@map("docente_grupos")
}

/// Feriados nacionales/locales
model Feriado {
  id        String   @id @default(cuid())
  fecha     DateTime @unique @db.Date
  nombre    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feriados")
}

/// Mantenimiento programado de aulas/laboratorios
model MantenimientoAula {
  id              String        @id @default(cuid())
  aulaId          String        @map("aula_id")
  franjaHorariaId String        @map("franja_horaria_id")
  fecha           DateTime      @db.Date
  motivo          String
  createdAt       DateTime      @default(now()) @map("created_at")
  aula            Aula          @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  franjaHoraria   FranjaHoraria @relation(fields: [franjaHorariaId], references: [id], onDelete: Cascade)

  @@unique([aulaId, franjaHorariaId, fecha])
  @@map("mantenimiento_aulas")
}

/// Slots preasignados por la dirección de escuela (antes del llenado)
model Preasignacion {
  id              String           @id @default(cuid())
  docenteId       String           @map("docente_id")
  grupoId         String           @map("grupo_id")
  franjaHorariaId String           @map("franja_horaria_id")
  periodoId       String           @map("periodo_id")
  aulaId          String           @map("aula_id")
  tipo            TipoAsignacion
  motivo          String           @default("Designación por Dirección")
  createdAt       DateTime         @default(now()) @map("created_at")
  docente         Docente          @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  franjaHoraria   FranjaHoraria    @relation(fields: [franjaHorariaId], references: [id], onDelete: Cascade)
  grupo           Grupo            @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  periodo         PeriodoAcademico @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  @@unique([aulaId, franjaHorariaId, periodoId])
  @@map("preasignaciones")
}

/// Asignación de carga lectiva por el Departamento
model AsignacionCargaLectiva {
  id                  String               @id @default(cuid())
  docenteId           String               @map("docente_id")
  grupoId             String               @map("grupo_id")
  periodoId           String               @map("periodo_id")
  tipo                TipoAsignacion
  horasAsignadas      Int                  @map("horas_asignadas")
  compartido          Boolean              @default(false)
  docenteCompartidoId String?              @map("docente_compartido_id")
  grupoLaboratorio    Int?                 @map("grupo_laboratorio")
  distribucionId      String?              @map("distribucion_id")
  coberturaId         String?              @map("cobertura_id")
  rol                 RolAsignacionDocente @default(PRINCIPAL)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  docenteCompartido   Docente?             @relation("DocenteCompartido", fields: [docenteCompartidoId], references: [id])
  docente             Docente              @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  grupo               Grupo                @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  periodo             PeriodoAcademico     @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  distribucion        DistribucionLectiva? @relation(fields: [distribucionId], references: [id])
  cobertura           CoberturaComponente? @relation(fields: [coberturaId], references: [id])

  @@unique([docenteId, grupoId, periodoId, tipo, grupoLaboratorio])
  @@unique([coberturaId, docenteId, rol])
  @@map("asignaciones_carga_lectiva")
}

model DemandaAcademica {
  id            String                 @id @default(cuid())
  escuelaId     String                 @map("escuela_id")
  periodoId     String                 @map("periodo_id")
  estado        EstadoRevisionWorkflow @default(BORRADOR)
  observacion   String?
  enviadaPorId  String?                @map("enviada_por_id")
  enviadaEn     DateTime?              @map("enviada_en")
  revisadaPorId String?                @map("revisada_por_id")
  revisadaEn    DateTime?              @map("revisada_en")
  version       Int                    @default(1)
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  escuela       Escuela                @relation(fields: [escuelaId], references: [id], onDelete: Restrict)
  periodo       PeriodoAcademico       @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  enviadaPor    User?                  @relation("DemandaEnviadaPor", fields: [enviadaPorId], references: [id])
  revisadaPor   User?                  @relation("DemandaRevisadaPor", fields: [revisadaPorId], references: [id])
  lineas        DemandaLinea[]

  @@unique([escuelaId, periodoId])
  @@map("demandas_academicas")
}

model DemandaLinea {
  id                        String                  @id @default(cuid())
  demandaId                 String                  @map("demanda_id")
  cursoId                   String                  @map("curso_id")
  departamentoId            String                  @map("departamento_id")
  horasTeoria               Int                     @map("horas_teoria")
  horasPractica             Int                     @map("horas_practica")
  horasLaboratorio          Int                     @map("horas_laboratorio")
  numGruposLaboratorio      Int                     @default(0) @map("num_grupos_laboratorio")
  motivoAperturaExcepcional String?                 @map("motivo_apertura_excepcional")
  createdAt                 DateTime                @default(now()) @map("created_at")
  updatedAt                 DateTime                @updatedAt @map("updated_at")
  demanda                   DemandaAcademica        @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  curso                     Curso                   @relation(fields: [cursoId], references: [id], onDelete: Restrict)
  departamento              Departamento            @relation(fields: [departamentoId], references: [id], onDelete: Restrict)
  curriculas                DemandaLineaCurricula[]
  coberturas                CoberturaComponente[]
  grupos                    Grupo[]

  @@unique([demandaId, cursoId])
  @@index([departamentoId])
  @@map("demanda_lineas")
}

model DemandaLineaCurricula {
  id             String       @id @default(cuid())
  demandaLineaId String       @map("demanda_linea_id")
  curriculaId    String       @map("curricula_id")
  ciclo          Int
  createdAt      DateTime     @default(now()) @map("created_at")
  demandaLinea   DemandaLinea @relation(fields: [demandaLineaId], references: [id], onDelete: Cascade)
  curricula      Curricula    @relation(fields: [curriculaId], references: [id], onDelete: Restrict)

  @@unique([demandaLineaId, curriculaId])
  @@map("demanda_lineas_curriculas")
}

model DistribucionLectiva {
  id             String                   @id @default(cuid())
  departamentoId String                   @map("departamento_id")
  periodoId      String                   @map("periodo_id")
  estado         EstadoRevisionWorkflow   @default(BORRADOR)
  observacion    String?
  enviadaPorId   String?                  @map("enviada_por_id")
  enviadaEn      DateTime?                @map("enviada_en")
  revisadaPorId  String?                  @map("revisada_por_id")
  revisadaEn     DateTime?                @map("revisada_en")
  version        Int                      @default(1)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  departamento   Departamento             @relation(fields: [departamentoId], references: [id], onDelete: Restrict)
  periodo        PeriodoAcademico         @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  enviadaPor     User?                    @relation("DistribucionEnviadaPor", fields: [enviadaPorId], references: [id])
  revisadaPor    User?                    @relation("DistribucionRevisadaPor", fields: [revisadaPorId], references: [id])
  coberturas     CoberturaComponente[]
  asignaciones   AsignacionCargaLectiva[]

  @@unique([departamentoId, periodoId])
  @@map("distribuciones_lectivas")
}

model CoberturaComponente {
  id               String                   @id @default(cuid())
  distribucionId   String                   @map("distribucion_id")
  demandaLineaId   String                   @map("demanda_linea_id")
  componente       TipoComponenteLectivo
  grupoLaboratorio Int                      @default(0) @map("grupo_laboratorio")
  estado           EstadoCobertura          @default(PENDIENTE)
  motivoPendiente  String?                  @map("motivo_pendiente")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  distribucion     DistribucionLectiva      @relation(fields: [distribucionId], references: [id], onDelete: Cascade)
  demandaLinea     DemandaLinea             @relation(fields: [demandaLineaId], references: [id], onDelete: Restrict)
  asignaciones     AsignacionCargaLectiva[]

  @@unique([distribucionId, demandaLineaId, componente, grupoLaboratorio])
  @@map("coberturas_componentes")
}

model ProcesoHorarioEscuela {
  id             String               @id @default(cuid())
  escuelaId      String               @map("escuela_id")
  periodoId      String               @map("periodo_id")
  estado         EstadoProcesoHorario @default(BORRADOR)
  observacion    String?
  revisadoPorId  String?              @map("revisado_por_id")
  revisadoEn     DateTime?            @map("revisado_en")
  publicadoPorId String?              @map("publicado_por_id")
  publicadoEn    DateTime?            @map("publicado_en")
  version        Int                  @default(1)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  escuela        Escuela              @relation(fields: [escuelaId], references: [id], onDelete: Restrict)
  periodo        PeriodoAcademico     @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  revisadoPor    User?                @relation("ProcesoHorarioRevisadoPor", fields: [revisadoPorId], references: [id])
  publicadoPor   User?                @relation("ProcesoHorarioPublicadoPor", fields: [publicadoPorId], references: [id])
  grupos         Grupo[]
  asignaciones   Asignacion[]

  @@unique([escuelaId, periodoId])
  @@map("procesos_horario_escuela")
}

model CargoDocente {
  id             String           @id @default(cuid())
  docenteId      String           @map("docente_id")
  periodoId      String           @map("periodo_id")
  cargo          CargoAcademico
  departamentoId String?          @map("departamento_id")
  escuelaId      String?          @map("escuela_id")
  facultadId     String?          @map("facultad_id")
  resolucion     String?
  evidencia      Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  docente        Docente          @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  periodo        PeriodoAcademico @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  departamento   Departamento?    @relation(fields: [departamentoId], references: [id])
  escuela        Escuela?         @relation(fields: [escuelaId], references: [id])
  facultad       Facultad?        @relation(fields: [facultadId], references: [id])

  @@unique([docenteId, periodoId, cargo])
  @@map("cargos_docentes")
}

model ReglaCargaPorCargo {
  id                   String              @id @default(cuid())
  cargo                CargoAcademico
  codigoActividad      String              @map("codigo_actividad")
  tipoCargaNoLectiva   TipoCargaNoLectiva? @map("tipo_carga_no_lectiva")
  horasLectivasMinimas Int?                @map("horas_lectivas_minimas")
  horasNoLectivas      Int?                @map("horas_no_lectivas")
  requiereEvidencia    Boolean             @default(true) @map("requiere_evidencia")
  activa               Boolean             @default(true)
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@unique([cargo, codigoActividad])
  @@map("reglas_carga_por_cargo")
}

model PublicacionAcademica {
  id             String           @id @default(cuid())
  facultadId     String           @map("facultad_id")
  periodoId      String           @map("periodo_id")
  snapshot       Json
  documentHashes Json             @map("document_hashes")
  publicadaPorId String           @map("publicada_por_id")
  publicadaEn    DateTime         @default(now()) @map("publicada_en")
  version        Int              @default(1)
  facultad       Facultad         @relation(fields: [facultadId], references: [id], onDelete: Restrict)
  periodo        PeriodoAcademico @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  publicadaPor   User             @relation("PublicacionRealizadaPor", fields: [publicadaPorId], references: [id])

  @@unique([facultadId, periodoId])
  @@map("publicaciones_academicas")
}

model MigracionReconciliacion {
  id            String    @id @default(cuid())
  codigo        String
  entidad       String
  entidadId     String?   @map("entidad_id")
  detalle       Json
  blocking      Boolean   @default(true)
  resueltaEn    DateTime? @map("resuelta_en")
  resueltaPorId String?   @map("resuelta_por_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  resueltaPor   User?     @relation("ReconciliacionResueltaPor", fields: [resueltaPorId], references: [id])

  @@index([blocking, resueltaEn])
  @@map("migracion_reconciliaciones")
}

/// Carga no lectiva del docente
model CargaNoLectiva {
  id              String                  @id @default(cuid())
  docenteId       String                  @map("docente_id")
  periodoId       String                  @map("periodo_id")
  tipo            TipoCargaNoLectiva
  horas           Int
  descripcion     String?
  codigoProyecto  String?                 @map("codigo_proyecto")
  nombreProyecto  String?                 @map("nombre_proyecto")
  numAlumnos      Int?                    @map("num_alumnos")
  cicloConsejeria String?                 @map("ciclo_consejeria")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  docente         Docente                 @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  periodo         PeriodoAcademico        @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  horarios        HorarioCargaNoLectiva[]

  @@map("cargas_no_lectivas")
}

/// Bloques horarios de cada actividad no lectiva
model HorarioCargaNoLectiva {
  id               String         @id @default(cuid())
  cargaNoLectivaId String         @map("carga_no_lectiva_id")
  dia              DiaSemana
  horaInicio       String         @map("hora_inicio")
  horaFin          String         @map("hora_fin")
  lugar            String?
  aula             String?
  createdAt        DateTime       @default(now()) @map("created_at")
  cargaNoLectiva   CargaNoLectiva @relation(fields: [cargaNoLectivaId], references: [id], onDelete: Cascade)

  @@map("horarios_carga_no_lectiva")
}

/// Declaración de carga horaria (Formato N°1 + control de flujo)
model DeclaracionCarga {
  id                       String                  @id @default(cuid())
  docenteId                String                  @map("docente_id")
  periodoId                String                  @map("periodo_id")
  estado                   EstadoDeclaracion       @default(BORRADOR)
  totalHorasLectivas       Int                     @default(0) @map("total_horas_lectivas")
  totalHorasNoLectivas     Int                     @default(0) @map("total_horas_no_lectivas")
  totalHoras               Int                     @default(0) @map("total_horas")
  aprobadoDepartamentoId   String?                 @map("aprobado_departamento_id")
  fechaAprobacionDepto     DateTime?               @map("fecha_aprobacion_depto")
  aprobadoEscuelaId        String?                 @map("aprobado_escuela_id")
  fechaAprobacionEscuela   DateTime?               @map("fecha_aprobacion_escuela")
  vistoBuenoDecanoId       String?                 @map("visto_bueno_decano_id")
  fechaVistoBueno          DateTime?               @map("fecha_visto_bueno")
  observaciones            String?
  declaracionJuradaFirmada Boolean                 @default(false) @map("declaracion_jurada_firmada")
  declaracionSedesFirmada  Boolean                 @default(false) @map("declaracion_sedes_firmada")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  aprobadorDepto           User?                   @relation("AprobadorDepto", fields: [aprobadoDepartamentoId], references: [id])
  aprobadorEscuela         User?                   @relation("AprobadorEscuela", fields: [aprobadoEscuelaId], references: [id])
  docente                  Docente                 @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  periodo                  PeriodoAcademico        @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  vbDecano                 User?                   @relation("VBDecano", fields: [vistoBuenoDecanoId], references: [id])
  firmasDigitales          DocumentoFirmaDigital[]

  @@unique([docenteId, periodoId])
  @@map("declaraciones_carga")
}

model DocumentoFirmaDigital {
  id                String               @id @default(cuid())
  declaracionId     String               @map("declaracion_id")
  tipo              TipoDocumentoFirma
  firmanteRol       RolFirmanteDocumento @default(DOCENTE) @map("firmante_rol")
  documentoHash     String               @map("documento_hash")
  algoritmoHash     String               @default("SHA-256") @map("algoritmo_hash")
  certificadoSerial String               @map("certificado_serial")
  certificadoEmisor String               @map("certificado_emisor")
  firmaPayload      String               @map("firma_payload")
  firmadoPorId      String               @map("firmado_por_id")
  firmadoEn         DateTime             @default(now()) @map("firmado_en")
  version           Int                  @default(1)
  cadenaCustodia    Json?                @map("cadena_custodia")
  createdAt         DateTime             @default(now()) @map("created_at")
  declaracion       DeclaracionCarga     @relation(fields: [declaracionId], references: [id], onDelete: Cascade)
  firmadoPor        User                 @relation("FirmanteDocumento", fields: [firmadoPorId], references: [id])

  @@unique([declaracionId, tipo, firmanteRol, version])
  @@index([documentoHash])
  @@map("documentos_firmas_digitales")
}

